# ANSI X12 Tool — environment configuration
# Copy to .env and fill in values

# CMS rate comparison thresholds
RATE_FLAG_OVER_PCT=300.0
RATE_FLAG_UNDER_PCT=100.0

# CMS Physician Fee Schedule conversion factor (update annually — CY2025 = 32.35)
PFS_CONVERSION_FACTOR=32.35

# Optional: CMS Procedure Price Lookup API key (developer.cms.gov)
# PPL_API_KEY=your_key_here

# Cache and DB paths (defaults to ~/.ansi_x12_tool/)
# CACHE_DIR=/path/to/cache
# DB_PATH=/path/to/billing.db
