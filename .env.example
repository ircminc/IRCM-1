# ─────────────────────────────────────────────────────────────────────────────
# ANSI X12 Medical Billing Converter — Environment Configuration
# Copy this file to .env and edit values for your environment.
# .env is git-ignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── CMS Rate Thresholds ────────────────────────────────────────────────────────
RATE_FLAG_OVER_PCT=300.0        # Flag if billed > 300% of Medicare → OVER_300PCT
RATE_FLAG_UNDER_PCT=100.0       # Flag if billed < 100% of Medicare → UNDER_100PCT

# ── CMS PFS Conversion Factor ─────────────────────────────────────────────────
# Update every January when CMS publishes the new annual rate
PFS_CONVERSION_FACTOR=32.35     # CY2025

# ── Storage Paths (optional — defaults to ~/.ansi_x12_tool/) ──────────────────
# TEMP_DIR=/path/to/tmp
# CACHE_DIR=/path/to/cms_cache
# DB_PATH=/path/to/billing.db
# AUDIT_LOG_PATH=/path/to/audit.jsonl

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                  # true = JSON structured logs (for log aggregators)

# ── HIPAA Mode ────────────────────────────────────────────────────────────────
# Set HIPAA_MODE=true to activate ALL protections below simultaneously
HIPAA_MODE=false

# Individual flags (can override independently of HIPAA_MODE)
HIPAA_ENCRYPT_UPLOADS=false     # Requires: pip install cryptography
HIPAA_MASK_PHI=false            # Mask patient names/DOB/IDs in outputs
HIPAA_NO_PERSISTENCE=false      # Process files without saving to database
HIPAA_SESSION_CLEANUP=true      # Auto-delete temp files when session ends

# ── Performance ────────────────────────────────────────────────────────────────
BACKGROUND_PROCESSING_THRESHOLD_MB=10   # Files >= this size use background thread

# ── CMS Cache ─────────────────────────────────────────────────────────────────
PFS_CACHE_DAYS=30               # Days before re-downloading PFS data
ASP_CHECK_DAYS=7                # Days between ASP quarterly check

# ── Optional CMS PPL API Key ──────────────────────────────────────────────────
# PPL_API_KEY=your_key_here
